fun updateRebirthUi(p) {
    val data = p.savedData
    val money = data["money"]
    val buy_idx = data["buy_mode_index"]
    val amount = BUY_AMOUNTS[buy_idx]
    val amount_name = BUY_NAMES[buy_idx]
    
    uiUpdate(p, "rebirth_count", "text", "Перерождения: " + data["rebirths"] + " (множитель x" + (data["rebirths"] + 1) + ")")
    uiUpdate(p, "rb_toggle_buy", "label", amount_name)
    
    val r_res = calcBulkBuy("rebirth", money, data["rebirths"], amount)
    val r_can_buy = r_res[0]
    val r_cost = r_res[1]
    val r_next = r_res[2]
    
    if (r_can_buy > 0) {
        uiUpdate(p, "do_rebirth", "label", "+" + r_can_buy + " реб. | " + formatNum(r_cost) + "$")
        uiUpdate(p, "do_rebirth", "color", "#AA44AA")
    } else {
        uiUpdate(p, "do_rebirth", "label", "Нужно " + formatNum(r_next) + "$")
        uiUpdate(p, "do_rebirth", "color", "#664444")
    }
}

on uiClick() -> uiClickHandler {
    val p = _event_player
    val btn = _event_widget
    if (p != null) {
        chat("§8[Debug] btn clicked: " + btn)
        initPlayerData(p)
        val data = p.savedData
        val my_npc = "clicker_npc"
        val money = data["money"]
        
        val buy_idx = data["buy_mode_index"]
        val amount = BUY_AMOUNTS[buy_idx]
        
        if (btn == "toggle_buy" || btn == "rb_toggle_buy") {
            val unl = data["unlocked_buy_index"]
            val new_idx = data["buy_mode_index"] + 1
            if (new_idx > unl) {
                data["buy_mode_index"] = 0
            } else {
                data["buy_mode_index"] = new_idx
            }
            playSound(p, "minecraft:ui.button.click", 1.0, 1.0)
            if (btn == "toggle_buy") { updateShopUi(p) }
            if (btn == "rb_toggle_buy") { updateRebirthUi(p) }
        } else if (btn == "unlock_buy") {
            val unl = data["unlocked_buy_index"]
            if (unl < 8) {
                val cost = UNLOCK_COSTS[unl + 1]
                if (money >= cost) {
                    data["money"] = money - cost
                    data["unlocked_buy_index"] = unl + 1
                    data["buy_mode_index"] = unl + 1
                    playSound(p, "minecraft:entity.player.levelup", 1.0, 2.0)
                } else {
                    playSound(p, "minecraft:block.note_block.bass", 1.0, 0.5)
                }
            }
            updateShopUi(p)
            updateHud(p)
        } else if (btn == "upg_power") {
            val res = calcBulkBuy("power", data["money"], data["click_power"], amount)
            val can_buy = res[0]
            val cost = res[1]
            if (can_buy > 0) {
                data["money"] = data["money"] - cost
                data["click_power"] = data["click_power"] + can_buy
                playSound(p, "minecraft:entity.player.levelup", 1.0, 2.0)
                my_npc.playOnce("yes")
            } else {
                playSound(p, "minecraft:block.note_block.bass", 1.0, 0.5)
            }
            updateShopUi(p)
            updateHud(p)
        } else if (btn == "upg_xp") {
            val res = calcBulkBuy("xp", data["money"], data["xp_power"], amount)
            val can_buy = res[0]
            val cost = res[1]
            if (can_buy > 0) {
                data["money"] = data["money"] - cost
                data["xp_power"] = data["xp_power"] + can_buy
                playSound(p, "minecraft:entity.player.levelup", 1.0, 2.0)
                my_npc.playOnce("yes")
            } else {
                playSound(p, "minecraft:block.note_block.bass", 1.0, 0.5)
            }
            updateShopUi(p)
            updateHud(p)
        } else if (btn == "open_rebirth") {
            chat("§8[Debug] Opening rebirth UI")
            uiOpen(p, rebirth_ui)
            updateRebirthUi(p)
            playSound(p, "minecraft:ui.button.click", 1.0, 1.0)
        } else if (btn == "back_shop") {
            chat("§8[Debug] Opening shop UI")
            uiOpen(p, shop_ui)
            updateShopUi(p)
            playSound(p, "minecraft:ui.button.click", 1.0, 1.0)
        } else if (btn == "do_rebirth") {
            val res = calcBulkBuy("rebirth", data["money"], data["rebirths"], amount)
            val can_buy = res[0]
            val cost = res[1]
            if (can_buy > 0) {
                data["money"] = 0
                data["level"] = 1
                data["xp"] = 0
                data["max_xp"] = 10
                data["click_power"] = 1
                data["xp_power"] = 1
                data["rebirths"] = data["rebirths"] + can_buy
                
                playSound(p, "minecraft:ui.toast.challenge_complete", 1.0, 1.0)
                particleSpiral("minecraft:totem_of_undying", p.x, p.y, p.z, 2.0, 3.0, 50, 0, 0, 0, 0)
                chat("§dВы совершили перерождение (" + formatNum(can_buy) + " раз)!")
                my_npc.playOnce("attack")
            } else {
                playSound(p, "minecraft:block.note_block.bass", 1.0, 0.5)
            }
            updateRebirthUi(p)
            updateHud(p)
        }
    }
}

on keybind("G") -> shopBind {
    val p = _event_player
    initPlayerData(p)
    uiOpen(p, shop_ui)
    updateShopUi(p)
}

on orbPickup() -> clickerOrb {
    val p = _event_player
    val tex = _event_texture
    if (tex == "minecraft:textures/item/gold_nugget.png") {
        initPlayerData(p)
        val data = p.savedData
        data["money"] = data["money"] + _event_amount
        updateHud(p)
    }
}

on clickBlock(block_x, block_y, block_z) -> blockClick {
    val p = _event_player
    initPlayerData(p)
    overlayOpen(p, main_hud)
    val data = p.savedData
    val power = data["click_power"]
    val xp_gain = data["xp_power"]
    val rebirth_mult = data["rebirths"] + 1
    
    val total_power = power * rebirth_mult
    val total_xp = xp_gain * rebirth_mult
    
    spawnOrb("minecraft:textures/item/gold_nugget.png", total_power, block_x + 0.5, block_y + 1.2, block_z + 0.5)
    
    data["xp"] = data["xp"] + total_xp
    particleSpawn("minecraft:happy_villager", block_x + 0.5, block_y + 1.2, block_z + 0.5, 3, 0.2, 0.2, 0.2, 0)
    playSound(p, "minecraft:entity.experience_orb.pickup", 0.5, 2.0)
    
    val my_npc = "clicker_npc"
    if (random() < 0.1) {
        my_npc.playOnce("attack")
    }
    
    var leveled_up = false
    while (data["xp"] >= data["max_xp"]) {
        data["xp"] = data["xp"] - data["max_xp"]
        data["level"] = data["level"] + 1
        data["max_xp"] = data["max_xp"] * 2
        leveled_up = true
    }
    
    if (leveled_up) {
        playSound(p, "minecraft:entity.player.levelup", 1.0, 1.0)
        chat("§eПоздравляем! Вы достигли §l" + formatNum(data["level"]) + "§e уровня!")
        particleSpawn("minecraft:totem_of_undying", p.x, p.y + 1.0, p.z, 50, 0.4, 0.5, 0.4, 0.15)
        particleSpiral("minecraft:happy_villager", p.x, p.y, p.z, 1.5, 2.0, 30, 0, 0, 0, 0)
        my_npc.alwaysLookAt(p)
        val r = random()
        val anim_name = ""
        val is_loop = false
        
        if (r < 0.2) {
            anim_name = "happy"
            my_npc.playFreeze(anim_name)
            npc_chat(p, my_npc, "Ого, растешь на глазах!", "#FFFFFF")
        } else if (r < 0.4) {
            anim_name = "Sweat"
            my_npc.playOnce(anim_name)
            npc_chat(p, my_npc, "Фух... Не устал еще кликать?", "#FFFFFF")
        } else if (r < 0.6) {
            anim_name = "crossArm"
            my_npc.playOnce(anim_name)
            npc_chat(p, my_npc, "Хм, неплохо, неплохо...", "#FFFFFF")
        } else if (r < 0.8) {
            anim_name = "Hands"
            my_npc.playOnce(anim_name)
            npc_chat(p, my_npc, "Давай, жми сильнее!", "#FFFFFF")
        } else {
            anim_name = "disgust"
            is_loop = true
            my_npc.playLoop(anim_name)
            npc_chat(p, my_npc, "Опять новый уровень... Как же ты задолбал.", "#FFFFFF")
        }
        
        async {
            await time(3)
            if (is_loop) {
                my_npc.stop(anim_name)
            }
            my_npc.alwaysLookAt(block_x, block_y, block_z)
        }
    }
    updateHud(p)
}

async {
    await time(1)
    val start_player = getNearestPlayer("clicker_npc")
    if (start_player != null) {
        initPlayerData(start_player)
        overlayOpen(start_player, main_hud)
        updateHud(start_player)
        npc_chat(start_player, "clicker_npc", "Добро пожаловать! Кликай по золотому блоку!", "§e")
    }
}
