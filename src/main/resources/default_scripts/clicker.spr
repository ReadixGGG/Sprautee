fun updateShopUi(p) {
    val data = p.savedData
    val money = data["money"]
    val buy_idx = data["buy_mode_index"]
    val unl_idx = data["unlocked_buy_index"]
    
    val amount = BUY_AMOUNTS[buy_idx]
    val amount_name = BUY_NAMES[buy_idx]
    
    uiUpdate(p, "shop_money_text", "text", "Баланс: $ " + formatNum(money))
    uiUpdate(p, "toggle_buy", "label", amount_name)
    
    if (unl_idx < 8) {
        val next_cost = UNLOCK_COSTS[unl_idx + 1]
        val next_name = BUY_NAMES[unl_idx + 1]
        uiUpdate(p, "unlock_buy", "label", next_name + " за " + formatNum(next_cost) + "$")
        uiUpdate(p, "unlock_buy", "color", "#AA55AA")
    } else {
        uiUpdate(p, "unlock_buy", "label", "Всё открыто!")
        uiUpdate(p, "unlock_buy", "color", "#555555")
    }
    
    val p_res = calcBulkBuy("power", money, data["click_power"], amount)
    val p_can_buy = p_res[0]
    val p_cost = p_res[1]
    val p_next = p_res[2]
    if (p_can_buy > 0) {
        uiUpdate(p, "upg_power", "label", "Сила +" + p_can_buy + " | " + formatNum(p_cost) + "$")
        uiUpdate(p, "upg_power", "color", "#44AA44")
    } else {
        uiUpdate(p, "upg_power", "label", "Сила | нужно " + formatNum(p_next) + "$")
        uiUpdate(p, "upg_power", "color", "#664444")
    }
    
    val x_res = calcBulkBuy("xp", money, data["xp_power"], amount)
    val x_can_buy = x_res[0]
    val x_cost = x_res[1]
    val x_next = x_res[2]
    if (x_can_buy > 0) {
        uiUpdate(p, "upg_xp", "label", "Опыт +" + x_can_buy + " | " + formatNum(x_cost) + "$")
        uiUpdate(p, "upg_xp", "color", "#4444AA")
    } else {
        uiUpdate(p, "upg_xp", "label", "Опыт | нужно " + formatNum(x_next) + "$")
        uiUpdate(p, "upg_xp", "color", "#444466")
    }
}

