fun updateHud(p) {
    val data = p.savedData
    val money = data["money"]
    val lvl = data["level"]
    val xp = data["xp"]
    val max_xp = data["max_xp"]
    val rebirths = data["rebirths"]
    
    val m_str = "$ " + formatNum(money)
    val r_str = "Перерождения: " + formatNum(rebirths) + " (x" + formatNum(rebirths + 1) + ")"
    
    uiUpdate(p, "money_text", "text", m_str)
    uiUpdate(p, "rebirth_text", "text", r_str)
    
    val len_m = m_str.length() * 1.5
    val len_r = r_str.length() * 0.8
    var max_len = len_m
    if (len_r > max_len) { max_len = len_r }
    
    val w_pct = max_len * 1 + 2.0
    val x_pct = 99.0 - w_pct
    uiUpdate(p, "money_bg", "w", w_pct + "%")
    uiUpdate(p, "money_bg", "x", x_pct + "%")
    
    uiUpdate(p, "level_text", "text", "Ур: " + formatNum(lvl) + " (" + formatNum(xp) + "/" + formatNum(max_xp) + ")")
    
    val percent = (xp * 100) / max_xp
    val width_percent = (percent * 30) / 100
    uiUpdate(p, "xp_fill", "w", width_percent + "%")
}

