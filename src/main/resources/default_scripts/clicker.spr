startScript("spraute_chat")
import("spraute_chat")

global val BUY_AMOUNTS = [1, 2, 3, 5, 10, 30, 50, 100, -1]
global val BUY_NAMES = ["x1", "x2", "x3", "x5", "x10", "x30", "x50", "x100", "MAX"]
global val UNLOCK_COSTS = [0, 500, 2500, 10000, 50000, 250000, 1000000, 5000000, 25000000]

val block_x = 16
val block_y = -60
val block_z = -3
setBlock(block_x, block_y, block_z, "minecraft:gold_block")

create npc clicker_npc {
    name = "§e§lХранитель Блока"
    hp = 20
    pos = block_x + 2, block_y, block_z
    show_name = true
    model = "geo/defolt.geo.json"
    texture = "textures/entity/knight.png"
    animation = "animations/npc_classic.animation.json"
}

clicker_npc.alwaysLookAt(block_x, block_y, block_z)

fun formatNum(n) {
    if (n == null) { return "0" }
    if (n < 0) {
        return "-" + formatNum(0 - n)
    }
    if (n < 1000) {
        return n // 1
    }
    if (n < 1000000) {
        val t = (n / 10.0) // 1
        return t / 100.0 + "k"
    }
    if (n < 1000000000) {
        val t = (n / 10000.0) // 1
        return t / 100.0 + "M"
    }
    val t = (n / 10000000.0) // 1
    return t / 100.0 + "B"
}

fun initPlayerData(p) {
    if (p == null) { return }
    val data = p.savedData
    if (data == null) { return }
    if (data["money"] == null) {
        data["money"] = 0
        data["level"] = 1
        data["xp"] = 0
        data["max_xp"] = 10
        data["click_power"] = 1
        data["xp_power"] = 1
    }
    if (data["rebirths"] == null) {
        data["rebirths"] = 0
        data["unlocked_buy_index"] = 0
        data["buy_mode_index"] = 0
    }
}

fun calcBulkBuy(type, money, current_level, target_amount) {
    var can_buy = 0
    var total_cost = 0
    var current_cost = 0
    if (type == "power") { current_cost = 50 + (current_level - 1) * 10 }
    if (type == "xp") { current_cost = 100 + (current_level - 1) * 20 }
    if (type == "rebirth") { current_cost = 100000 * (current_level + 1) }
    
    if (current_cost < 1) { current_cost = 1 }
    
    var temp_money = money
    var max_limit = target_amount
    if (max_limit == -1) { max_limit = 500 }
    
    while (can_buy < max_limit) {
        if (current_cost < 1) { break }
        if (temp_money < current_cost) { break }
        can_buy = can_buy + 1
        total_cost = total_cost + current_cost
        temp_money = temp_money - current_cost
        if (type == "power") { current_cost = 50 + (current_level + can_buy - 1) * 10 }
        if (type == "xp") { current_cost = 100 + (current_level + can_buy - 1) * 20 }
        if (type == "rebirth") { current_cost = 100000 * (current_level + can_buy + 1) }
    }
    
    return [can_buy, total_cost, current_cost]
}

