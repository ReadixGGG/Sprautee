{
  "name": "spraute-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Редактор скриптов Spraute — оболочка в духе VS Code для папки Minecraft",
  "author": {
    "name": "ZonarStudio",
    "email": "contact@zonarstudio.com"
  },
  "homepage": "https://github.com/ReadixGG/Spraute",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "npx concurrently -k \"npx vite\" \"npx wait-on http://127.0.0.1:5173 && npx electron .\"",
    "build": "npx vite build",
    "start": "npx electron .",
    "preview": "npx vite build && npx electron .",
    "studio": "npm run dev"
  },
  "dependencies": {
    "@codemirror/lint": "^6.9.5",
    "codemirror": "^6.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "org.zonarstudio.spraute.studio",
    "productName": "Spraute Studio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon_spraute.icns",
      "target": {
        "target": "default",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "win": {
      "icon": "assets/icon_spraute.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon_spraute.png",
      "maintainer": "ZonarStudio <contact@zonarstudio.com>",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://85.239.59.203/studio-updates/"
      }
    ]
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21",
    "wait-on": "^8.0.5"
  },
  "keywords": [],
  "license": "ISC"
}
